{
  "name": "jupiter-toys-pw-ts",
  "version": "1.0.0",
  "description": "End-to-end UI test automation using Playwright and TypeScript following Page Object Model",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chrome": "playwright test --project=Chrome",
    "test:edge": "playwright test --project=Edge",
    "test:single": "playwright test",
    "test:list": "playwright test --list",
    "report": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "dotenv": "^16.3.0"
  }
}
